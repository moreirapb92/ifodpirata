# =============================================================================
# Configuracao do AGENTE LOCAL (Firebird -> Portal Online)
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# O agente le as variaveis do ambiente ou do arquivo .env automaticamente.
#
# Exemplo no Windows:
#   copy .env.example .env
#   notepad .env
#
# Depois execute:
#   python run_agent.py          # sync continuo
#   python sync_once_online.py   # sync unico
#   python testar_portal_online.py  # testar conexao
# =============================================================================

# URL do portal online (Render)
PORTAL_URL=https://ifodpirata.onrender.com

# Chave de API gerada no Render (Dashboard > Environment > PORTAL_API_KEY)
PORTAL_API_KEY=COLOQUE_SUA_CHAVE_AQUI

# Modo online: ative quando PORTAL_URL apontar para o Render
# MODO_ONLINE=true desativa importacao direta no Firebird pelo portal
MODO_ONLINE=false

# Firebird (deixe FB_HOST vazio para conexao local)
FB_HOST=
FB_DATABASE=C:\TSD\Host\HOST.FDB
FB_USER=SYSDBA
FB_PASSWORD=masterkey

# Comportamento
DESTINO_PEDIDO=ORCAMENTO
DRY_RUN=false
SYNC_INTERVAL_SECONDS=60
